# Netlify local development variables for dashboard/functions

# Dashboard URL used by Discord OAuth callback in local dev
DISCORD_REDIRECT_URI=http://localhost:8888/.netlify/functions/discord-oauth

# Discord OAuth app credentials
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Stripe keys for checkout + webhook functions
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Optional backend for real dashboard data (status/panels/channels)
# If unset, dashboard still loads with fallback/mock behavior.
DASHBOARD_BACKEND_URL=http://127.0.0.1:8444

# Optional bot API target used by webhook notifications/update flow
BOT_API_URL=
BOT_API_KEY=

# Optional Discord webhook URL(s) for notifications
DISCORD_WEBHOOK_URL=
DISCORD_DONATION_WEBHOOK_URL=
